# Application
APP_NAME=azure-genai-backend-lab
APP_ENV=local
LOG_LEVEL=INFO

# Azure OpenAI (v1 GA API: no api-version; deployment name, not model name)
AZURE_OPENAI_ENDPOINT=https://example.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_DEPLOYMENT_NAME=chat-mini
# Explicit upstream timeout/retry policy; SDK defaults (600s, 2 retries) are for scripts.
# Timeout is per attempt, so worst-case wait is roughly (1 + retries) * timeout + backoff.
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://example.search.windows.net
AZURE_SEARCH_INDEX_NAME=documents

# Local development toggles
USE_FAKE_LLM=true
USE_FAKE_SEARCH=true
